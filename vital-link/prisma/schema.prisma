// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---
enum Role {
  TRIAGE_NURSE
  DOCTOR
  SITE_MANAGER
  CLEANER
  ADMIN
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING_REQUIRED
  MAINTENANCE
}

enum TriageColor {
  RED
  ORANGE
  YELLOW
  GREEN
  BLUE
}

// --- MODELS ---
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(TRIAGE_NURSE)
  password  String   
  createdAt DateTime @default(now())
}

model Ward {
  id          String   @id @default(uuid())
  name        String
  type        String
  beds        Bed[]
}

model Bed {
  id          String    @id @default(uuid())
  label       String
  version     Int       @default(0) // Optimistic Locking
  status      BedStatus @default(AVAILABLE)
  wardId      String
  ward        Ward      @relation(fields: [wardId], references: [id])
  patientId   String?   @unique
  patient     Patient?  @relation(fields: [patientId], references: [id])
  updatedAt   DateTime  @updatedAt
}

model Patient {
  id            String       @id @default(uuid())
  firstName     String
  lastName      String
  dob           DateTime
  gender        String
  nhsNumber     String       @unique
  triageColor   TriageColor
  triageScore   Int
  chiefComplaint String
  news2Score    Int          @default(0)
  heartRate     Int?
  bpSystolic    Int?
  bpDiastolic   Int?
  temperature   Float?
  oxygenSat     Int?
  admissionDate DateTime     @default(now())
  bed           Bed?
  history       ClinicalLog[]
}

model ClinicalLog {
  id          String   @id @default(uuid())
  message     String
  authorName  String
  timestamp   DateTime @default(now())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
}